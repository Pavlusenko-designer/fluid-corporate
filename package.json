{
  "name": "fluid-corporate",
  "version": "0.1.0",
  "private": true,
  "description": "Production-ready Next.js + Sanity corporate website monorepo",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules dist .turbo",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v",
    "docker:logs:web": "docker compose logs -f web",
    "docker:logs:studio": "docker compose logs -f studio",
    "docker:restart:web": "docker compose restart web",
    "docker:restart:studio": "docker compose restart studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "turbo": "^1.13.2",
    "typescript": "^5.3.3"
  }
}
